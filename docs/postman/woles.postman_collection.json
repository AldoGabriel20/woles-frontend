{
  "info": {
    "_postman_id": "woles-api-v1",
    "name": "Woles API",
    "description": "Woles — WhatsApp-first personal life administration assistant.\n\nAll authenticated requests require a valid RS256 JWT in the Authorization header.\nRefresh tokens are stored as HttpOnly cookies and are managed automatically.\n\n**Setup:**\n1. Import `woles.postman_environment.json` alongside this collection.\n2. Select **Woles — Local Development** environment.\n3. Run **⚙ Init — Get CSRF Token** once to seed the CSRF token.\n4. Run **Register** or **Login** to get an access token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{access_token}}", "type": "string" }]
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// ── 1. Auto-refresh access token when it expires within 30 s ────────",
          "const token = pm.environment.get('access_token');",
          "if (token) {",
          "    try {",
          "        const payload = JSON.parse(atob(token.split('.')[1]));",
          "        const exp = payload.exp || 0;",
          "        const nowSec = Math.floor(Date.now() / 1000);",
          "        if (exp - nowSec < 30) {",
          "            const baseUrl = pm.environment.get('base_url') || 'http://localhost:8080/api/v1';",
          "            // NOTE: pm.sendRequest is async — new token applies from the NEXT request.",
          "            pm.sendRequest({ url: baseUrl + '/auth/refresh', method: 'POST' },",
          "                function(err, res) {",
          "                    if (!err && res.code === 200) {",
          "                        const body = res.json();",
          "                        if (body.access_token) pm.environment.set('access_token', body.access_token);",
          "                    }",
          "                }",
          "            );",
          "        }",
          "    } catch(e) {}",
          "}",
          "",
          "// ── 2. Inject X-CSRF-Token on mutating requests ──────────────────────",
          "// The csrf_token env var is populated by the ⚙ Init request.",
          "// pm.request.headers.upsert only works synchronously (NOT inside a callback).",
          "if (['POST','PATCH','DELETE'].includes(pm.request.method)) {",
          "    const csrf = pm.environment.get('csrf_token');",
          "    if (csrf) {",
          "        pm.request.headers.upsert({ key: 'X-CSRF-Token', value: csrf });",
          "    } else {",
          "        console.warn('csrf_token is empty — run ⚙ Init first to seed it');",
          "    }",
          "}"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "⚙ Init — Get CSRF Token",
      "item": [
        {
          "name": "Get CSRF Token (run this first)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Extracts csrf_token from Set-Cookie and saves to environment.",
                  "// Run once before any POST/PATCH/DELETE request.",
                  "const setCookie = pm.response.headers.get('Set-Cookie') || '';",
                  "const match = setCookie.match(/csrf_token=([^;]+)/);",
                  "if (match) {",
                  "    pm.environment.set('csrf_token', match[1]);",
                  "    pm.test('CSRF token saved (' + match[1].substring(0,10) + '...)', () => pm.expect(match[1]).to.be.a('string').with.lengthOf.above(10));",
                  "} else {",
                  "    pm.test('CSRF token received', () => { throw new Error('csrf_token not found in Set-Cookie — check server is running'); });",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:8080/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["health"]
            },
            "description": "GET /health — causes the server to set the `csrf_token` cookie. The test script extracts and saves it to the environment variable. **Run this once** before making POST/PATCH/DELETE requests, or whenever the token expires (24 h)."
          }
        }
      ]
    },
